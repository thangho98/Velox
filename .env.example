# Velox Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# Data & Server Configuration
# =============================================================================

# Data directory for database, transcodes, and cached files
# Default: ~/.velox
# VELOX_DATA_DIR=/path/to/velox/data

# Server bind address and port
# VELOX_HOST=0.0.0.0
# VELOX_PORT=8080

# CORS origin for development (frontend dev server)
# VELOX_CORS_ORIGIN=http://localhost:5173

# =============================================================================
# Hardware Transcoding (optional)
# =============================================================================

# Hardware acceleration: auto, videotoolbox, vaapi, nvenc, qsv, or none
# VELOX_HW_ACCEL=auto

# Maximum concurrent transcode jobs
# VELOX_MAX_TRANSCODES=2

# =============================================================================
# Trickplay Thumbnails (optional)
# =============================================================================

# Enable trickplay/thumbnail scrubbing
# VELOX_TRICKPLAY_ENABLED=false

# Seconds between thumbnail frames
# VELOX_TRICKPLAY_INTERVAL=10

# =============================================================================
# Metadata Provider API Keys (optional)
# =============================================================================
# These API keys are used as defaults when users haven't configured custom keys
# in Settings → Metadata. Set these if you want to provide built-in keys for
# your users (e.g., for an open-source distribution).
#
# If not set, users must provide their own API keys for metadata enrichment.

# TMDb (The Movie Database) - v4 Read Access Token
# Get your free key at: https://www.themoviedb.org/settings/api
# VELOX_TMDB_API_KEY=eyJhbGciOiJIUzI1NiJ9...

# OMDb (Open Movie Database)
# Get your free key at: https://www.omdbapi.com/apikey.aspx
# VELOX_OMDB_API_KEY=your_omdb_key

# TheTVDB
# Get your free key at: https://thetvdb.com/api-information
# VELOX_TVDB_API_KEY=your_tvdb_key

# Fanart.tv
# Get your free key at: https://fanart.tv/get-an-api-key/
# VELOX_FANART_API_KEY=your_fanart_key

# Subdl (Subtitles)
# Get your free key at: https://subdl.com/panel/api
# VELOX_SUBDL_API_KEY=your_subdl_key
