# Velox Environment Configuration

# Required: Data directory for database, transcodes, and cached files
VELOX_DATA_DIR=/path/to/velox/data

# Server Configuration
VELOX_HOST=0.0.0.0
VELOX_PORT=8080
VELOX_CORS_ORIGIN=http://localhost:5173

# Hardware Transcoding (Plan E)
# Options: auto, videotoolbox, vaapi, nvenc, qsv, none
VELOX_HW_ACCEL=auto
VELOX_MAX_TRANSCODES=2

# Trickplay Thumbnails (Plan E Phase 03)
VELOX_TRICKPLAY_ENABLED=false
VELOX_TRICKPLAY_INTERVAL=10

# File Watcher (Phase 03)
VELOX_FILE_WATCHER=true

# =============================================================================
# OPTIONAL: Built-in API Keys for Metadata Providers
# =============================================================================
# If set, these act as default keys when users haven't configured custom keys.
# For open-source distribution, leave these empty and let users add their own keys.
# For personal deployment, add your keys here so all users can use them.

# TMDb API (v4 read access token) - https://www.themoviedb.org/settings/api
VELOX_TMDB_API_KEY=

# OMDb API Key - https://www.omdbapi.com/apikey.aspx
VELOX_OMDB_API_KEY=

# TheTVDB API Key - https://thetvdb.com/subscribe (API key tier)
VELOX_TVDB_API_KEY=

# Fanart.tv API Key - https://fanart.tv/get-an-api-key/
VELOX_FANART_API_KEY=

# Subdl API Key - https://subdl.com/panel
VELOX_SUBDL_API_KEY=
